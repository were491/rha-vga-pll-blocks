.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice diode_typical
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice res_typical
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice mimcap_typical
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice moscap_typical
.option method=gear

VDD_src VDD 0 DC 3.3
* GND_src GND 0 DC 0
Vin_src Vin 0 DC 1.65 AC 10m 0
Vin_n_src Vin_n 0 DC 1.65 AC 10m 180

VCP5_src Vcp_5 0 DC 3.3
VCP4_src Vcp_4 0 DC 3.3
VCP3_src Vcp_3 0 DC 3.3
VCP2_src Vcp_2 0 DC 3.3
VCP1_src Vcp_1 0 DC 3.3
VCP0_src Vcp_0 0 DC 3.3

.control
set temp = 25
  * 1. Setup the sweep parameters
  let v_ctrl = 3.3

  let f_start = 1
  let f_stop = 3.2G
  let f_points = 120
  
  * 2. Initialize vectors to store results
  let gain_db = unitvec(f_points)
  
  alter v3 = v_ctrl
  ac dec $&f_points $&f_start $&f_stop
    
  * 4. Calculate Differential Gain in dB
  * Formula: 20 * log10(|Vout_diff| / |Vin_diff|)
  let vin_mag = mag(v(vin) - v(vin_n))
  let vout_s_mag = mag(v(vout))
  let vout_buf_mag = mag(v(vout) - v(vout_n))
  let vout_s_gain = 20 * log10(vout_s_mag / vin_mag)
  let vout_buf_gain = 20 * log10(vout_buf_mag / vin_mag)

  * Credit to marcel hendrix
  * https://sourceforge.net/p/ngspice/discussion/133842/thread/2031ad61/
  meas ac peak  MAX  vout_s_mag FROM=$&f_start TO=$&f_stop
  let f3db = peak/sqrt(2)
  meas ac lo_3db WHEN vout_s_mag=f3db RISE=1
  meas ac hi_3db WHEN vout_s_mag=f3db FALL=1

  meas ac peak  MAX  vout_buf_mag FROM=$&f_start TO=$&f_stop
  let f3db = peak/sqrt(2)
  meas ac lo_3db WHEN vout_buf_mag=f3db RISE=1
  meas ac hi_3db WHEN vout_buf_mag=f3db FALL=1
  
  * 5. Save results to vectors
  plot vout_s_gain vout_buf_gain title 'Gain (dB) vs. Frequency from 1MHz to 3.2GHz, 0.6 vctrl' ylimit -20 60
.endc
"
}
